PORT=5000
# Comma-separated allowed origins in production (dev auto-allows any localhost port)
CLIENT_URL=http://localhost:5173

# Google OAuth — same client ID as VITE_GOOGLE_CLIENT_ID on the frontend
GOOGLE_CLIENT_ID=

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.example.mongodb.net/replyfy?appName=Cluster
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
